<Window x:Class="KooliProjekt.WPF.ProjectTaskWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Task Details" Height="450" Width="450" WindowStartupLocation="CenterOwner">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="Auto"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <Label Content="Title:" Grid.Row="0" VerticalAlignment="Center"/>
        <TextBox x:Name="TitleTextBox" Grid.Row="0" Grid.Column="1" Margin="5"/>

        <Label Content="Description:" Grid.Row="1" VerticalAlignment="Top"/>
        <TextBox x:Name="DescriptionTextBox" Grid.Row="1" Grid.Column="1" Margin="5" Height="60" TextWrapping="Wrap" AcceptsReturn="True"/>

        <Label Content="Status:" Grid.Row="2" VerticalAlignment="Center"/>
        <TextBox x:Name="StatusTextBox" Grid.Row="2" Grid.Column="1" Margin="5"/>

        <Label Content="Priority:" Grid.Row="3" VerticalAlignment="Center"/>
        <TextBox x:Name="PriorityTextBox" Grid.Row="3" Grid.Column="1" Margin="5"/>

        <Label Content="Deadline:" Grid.Row="4" VerticalAlignment="Center"/>
        <DatePicker x:Name="DeadlinePicker" Grid.Row="4" Grid.Column="1" Margin="5"/>

        <Label Content="Project:" Grid.Row="5" VerticalAlignment="Center"/>
        <ComboBox x:Name="ProjectComboBox" Grid.Row="5" Grid.Column="1" Margin="5" DisplayMemberPath="Name" SelectedValuePath="Id"/>

        <Label Content="Assigned To:" Grid.Row="6" VerticalAlignment="Center"/>
        <ComboBox x:Name="MemberComboBox" Grid.Row="6" Grid.Column="1" Margin="5" DisplayMemberPath="Name" SelectedValuePath="Id"/>

        <StackPanel Orientation="Horizontal" Grid.Row="8" Grid.ColumnSpan="2" HorizontalAlignment="Right">
            <Button x:Name="SaveButton" Content="Save" Width="80" Margin="5" Click="SaveButton_Click" IsDefault="True"/>
            <Button Content="Cancel" Width="80" Margin="5" IsCancel="True"/>
        </StackPanel>
    </Grid>
</Window>
