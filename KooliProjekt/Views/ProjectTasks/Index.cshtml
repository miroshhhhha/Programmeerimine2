@model IEnumerable<KooliProjekt.Models.ProjectTask>

@{
    ViewData["Title"] = "Tasks";
}

<div class="container mt-5">
    <h2>Task List</h2>
    <p>
        <a asp-action="Create" class="btn btn-primary">Create New Task</a>
    </p>
    <table class="table table-striped">
        <thead>
            <tr>
                <th>Title</th>
                <th>Project</th>
                <th>Status</th>
                <th>Priority</th>
                <th>Deadline</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var item in Model) {
                <tr>
                    <td>@item.Title</td>
                    <td>@(item.Project?.Name ?? "N/A")</td>
                    <td>@item.Status</td>
                    <td>@item.Priority</td>
                    <td>@(item.Deadline?.ToShortDateString() ?? "No deadline")</td>
                </tr>
            }
        </tbody>
    </table>
</div>
